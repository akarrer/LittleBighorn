# ── Model scale / position corrections ────────────────────────────────────────
# Tune these per-model after downloading. Values depend on the source file.
MODEL_CFG = {
    # key: (scale, z_offset, h_offset)
    # scale    — uniform scale so the character is ~1.8 units tall
    # z_offset — raise/lower so feet touch z=0
    # h_offset — rotate if model faces wrong direction (degrees)
    "trooper": (1.0,  0.0,  0.0),
    "horse":   (1.0,  0.0,  0.0),
    "warrior": (1.0,  0.0,  0.0),
    "dead":    (1.0,  0.0,  0.0),
}

