# ── Helpers ────────────────────────────────────────────────────────────────────
def vlen2(x, y): return math.hypot(x, y)
def vnorm2(x, y):
    l = vlen2(x, y)
    return (x/l, y/l) if l > 1e-6 else (0.0, 0.0)

# ── Procedural geometry (fallback when no .glb files present) ─────────────────

def _add_box(vw, nw, cw, cx, cy, cz, sx, sy, sz, r, g, b):
    hw, hh, hd = sx/2, sy/2, sz/2
    col = (r/255, g/255, b/255, 1)
    faces = [
        (( 0, 0, 1), [(-hw,-hd, hh),( hw,-hd, hh),( hw, hd, hh),(-hw, hd, hh)]),
        (( 0, 0,-1), [( hw,-hd,-hh),(-hw,-hd,-hh),(-hw, hd,-hh),( hw, hd,-hh)]),
        (( 1, 0, 0), [( hw,-hd,-hh),( hw, hd,-hh),( hw, hd, hh),( hw,-hd, hh)]),
        ((-1, 0, 0), [(-hw, hd,-hh),(-hw,-hd,-hh),(-hw,-hd, hh),(-hw, hd, hh)]),
        (( 0, 1, 0), [(-hw, hd,-hh),( hw, hd,-hh),( hw, hd, hh),(-hw, hd, hh)]),
        (( 0,-1, 0), [( hw,-hd,-hh),(-hw,-hd,-hh),(-hw,-hd, hh),( hw,-hd, hh)]),
    ]
    base = vw.getWriteRow()
    for (nx, ny, nz), corners in faces:
        for (dx, dy, dz) in corners:
            vw.addData3(cx+dx, cz+dy, cy+dz)
            nw.addData3(nx, ny, nz)
            cw.addData4(*col)
    return base

def _add_cyl(vw, nw, cw, cx, cy, cz, radius, height, r, g, b, steps=8):
    col = (r/255, g/255, b/255, 1)
    base = vw.getWriteRow()
    for i in range(steps):
        a0 = i/steps*math.pi*2; a1 = (i+1)/steps*math.pi*2
        x0,y0 = math.cos(a0)*radius, math.sin(a0)*radius
        x1,y1 = math.cos(a1)*radius, math.sin(a1)*radius
        for (dx,dy,dz,nx,ny) in [
            (x0,y0,0,x0,y0),(x1,y1,0,x1,y1),
            (x1,y1,height,x1,y1),(x0,y0,height,x0,y0)]:
            vw.addData3(cx+dx, cz+dy, cy+dz)
            nw.addData3(nx, ny, 0)
            cw.addData4(*col)
    return base

def _build_mesh(vdata, tris) -> NodePath:
    geom = Geom(vdata); geom.addPrimitive(tris)
    node = GeomNode("mesh"); node.addGeom(geom)
    np = NodePath(node)
    np.setColorOff(); np.setLightOff()
    return np

def _new_writers():
    fmt   = GeomVertexFormat.getV3n3c4()
    vdata = GeomVertexData("m", fmt, Geom.UHStatic)
    tris  = GeomTriangles(Geom.UHStatic)
    vw = GeomVertexWriter(vdata, "vertex")
    nw = GeomVertexWriter(vdata, "normal")
    cw = GeomVertexWriter(vdata, "color")
    return vdata, tris, vw, nw, cw

def _box_tris(tris, base):
    for f in range(6):
        b0 = base + f*4
        tris.addVertices(b0, b0+1, b0+2)
        tris.addVertices(b0, b0+2, b0+3)

def _cyl_tris(tris, base, steps=8):
    for i in range(steps):
        b0 = base + i*4
        tris.addVertices(b0, b0+1, b0+2)
        tris.addVertices(b0, b0+2, b0+3)

def make_trooper_model_proc() -> NodePath:
    vdata, tris, vw, nw, cw = _new_writers()
    def B(cx,cy,cz,sx,sy,sz,r,g,b): _box_tris(tris, _add_box(vw,nw,cw,cx,cy,cz,sx,sy,sz,r,g,b))
    def C(cx,cy,cz,rd,h,r,g,b):     _cyl_tris(tris, _add_cyl(vw,nw,cw,cx,cy,cz,rd,h,r,g,b))
    B(-0.13,0.00,0.0, 0.18,0.28,0.22, 28,18,10); B( 0.13,0.00,0.0, 0.18,0.28,0.22, 28,18,10)
    B(-0.13,0.28,0.0, 0.20,0.54,0.21, 52,65,88); B( 0.13,0.28,0.0, 0.20,0.54,0.21, 52,65,88)
    B(-0.22,0.40,0.0, 0.04,0.38,0.04, 180,148,40); B( 0.22,0.40,0.0, 0.04,0.38,0.04, 180,148,40)
    B( 0.0, 0.82,0.0, 0.48,0.52,0.26, 44,62,82)
    B( 0.0, 0.80,0.0, 0.50,0.06,0.28, 140,110,35)
    B(-0.32,0.90,0.0, 0.16,0.46,0.18, 44,62,82); B( 0.32,0.90,0.0, 0.16,0.46,0.18, 44,62,82)
    C(-0.32,0.84,0.0, 0.09,0.12, 200,165,120); C( 0.32,0.84,0.0, 0.09,0.12, 200,165,120)
    B( 0.0, 1.06,0.0, 0.16,0.40,0.16, 200,165,120)
    B( 0.0, 1.46,0.0, 0.28,0.32,0.26, 200,165,120)
    B( 0.0, 1.78,0.0, 0.42,0.06,0.40, 22,14,8); B( 0.0, 1.84,0.0, 0.26,0.24,0.28, 22,14,8)
    B( 0.0, 1.78,0.0, 0.28,0.05,0.30, 140,110,35)
    B( 0.42,0.72,0.0, 0.05,1.05,0.05, 55,42,20)
    root = _build_mesh(vdata, tris); root.setTwoSided(False)
    return root

def make_horse_model_proc() -> NodePath:
    vdata, tris, vw, nw, cw = _new_writers()
    def B(cx,cy,cz,sx,sy,sz,r,g,b): _box_tris(tris, _add_box(vw,nw,cw,cx,cy,cz,sx,sy,sz,r,g,b))
    HC=(110,70,30); HM=(35,20,10)
    B( 0.0,1.15, 0.0, 0.55,0.70,1.40,*HC); B( 0.0,1.25,-0.55,0.50,0.55,0.50,*HC)
    B( 0.0,1.10, 0.60,0.48,0.55,0.30,*HC); B( 0.0,1.55, 0.52,0.28,0.60,0.28,*HC)
    B( 0.0,1.60, 0.88,0.22,0.26,0.50,*HC); B( 0.0,1.48, 1.04,0.16,0.16,0.24, HC[0]-10,HC[1]-5,HC[2]-5)
    B(-0.09,1.82,0.82,0.06,0.14,0.06,*HM); B( 0.09,1.82,0.82,0.06,0.14,0.06,*HM)
    B( 0.0,1.72, 0.60,0.08,0.28,0.38,*HM)
    B(-0.18,0.56, 0.32,0.16,1.12,0.18,HC[0]-8,HC[1]-4,HC[2]-4)
