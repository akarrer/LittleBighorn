def vlen2(x,y): return math.hypot(x,y)
def vnorm2(x,y):
    l=vlen2(x,y); return (x/l,y/l) if l>1e-6 else (0.,0.)

# ── Geometry helpers ───────────────────────────────────────────────────────────

def _new_writers():
    fmt=GeomVertexFormat.getV3n3c4()
    vdata=GeomVertexData("m",fmt,Geom.UHStatic)
    tris=GeomTriangles(Geom.UHStatic)
    vw=GeomVertexWriter(vdata,"vertex")
    nw=GeomVertexWriter(vdata,"normal")
    cw=GeomVertexWriter(vdata,"color")
    return vdata,tris,vw,nw,cw

def _build_mesh(vdata,tris,two_sided=False) -> NodePath:
    geom=Geom(vdata); geom.addPrimitive(tris)
    node=GeomNode("mesh"); node.addGeom(geom)
    np=NodePath(node); np.setColorOff(); np.setLightOff()
    if two_sided: np.setTwoSided(True)
    return np

def _add_box(vw,nw,cw,cx,cy,cz,sx,sy,sz,r,g,b):
    hw,hh,hd=sx/2,sy/2,sz/2; col=(r/255,g/255,b/255,1)
    faces=[
        ((0,0,1),[(-hw,-hd,hh),(hw,-hd,hh),(hw,hd,hh),(-hw,hd,hh)]),
        ((0,0,-1),[(hw,-hd,-hh),(-hw,-hd,-hh),(-hw,hd,-hh),(hw,hd,-hh)]),
        ((1,0,0),[(hw,-hd,-hh),(hw,hd,-hh),(hw,hd,hh),(hw,-hd,hh)]),
        ((-1,0,0),[(-hw,hd,-hh),(-hw,-hd,-hh),(-hw,-hd,hh),(-hw,hd,hh)]),
        ((0,1,0),[(-hw,hd,-hh),(hw,hd,-hh),(hw,hd,hh),(-hw,hd,hh)]),
        ((0,-1,0),[(hw,-hd,-hh),(-hw,-hd,-hh),(-hw,-hd,hh),(hw,-hd,hh)]),
    ]
    base=vw.getWriteRow()
    for (nx,ny,nz),corners in faces:
        for (dx,dy,dz) in corners:
            vw.addData3(cx+dx,cz+dy,cy+dz); nw.addData3(nx,ny,nz); cw.addData4(*col)
    return base

def _add_cyl(vw,nw,cw,cx,cy,cz,radius,height,r,g,b,steps=8):
    col=(r/255,g/255,b/255,1); base=vw.getWriteRow()
    for i in range(steps):
        a0=i/steps*math.pi*2; a1=(i+1)/steps*math.pi*2
        x0,y0=math.cos(a0)*radius,math.sin(a0)*radius
        x1,y1=math.cos(a1)*radius,math.sin(a1)*radius
        for (dx,dy,dz,nx,ny) in [(x0,y0,0,x0,y0),(x1,y1,0,x1,y1),(x1,y1,height,x1,y1),(x0,y0,height,x0,y0)]:
            vw.addData3(cx+dx,cz+dy,cy+dz); nw.addData3(nx,ny,0); cw.addData4(*col)
    return base

def _box_tris(tris,base):
    for f in range(6):
        b0=base+f*4; tris.addVertices(b0,b0+1,b0+2); tris.addVertices(b0,b0+2,b0+3)

def _cyl_tris(tris,base,steps=8):
    for i in range(steps):
        b0=base+i*4; tris.addVertices(b0,b0+1,b0+2); tris.addVertices(b0,b0+2,b0+3)


# ── Articulated horse model — scene graph with named leg nodes ─────────────────

def make_horse_articulated(parent: NodePath) -> NodePath:
    """Horse with individually animatable leg NodePaths.
    Returns root; legs accessible as root.find('**/leg_*')."""
    root = parent.attachNewNode("horse_root")
    HC=(112,72,32); HD=(98,60,25); HM=(30,18,8)

    def solid(name, cx, cy, cz, sx, sy, sz, r, g, b) -> NodePath:
        vdata,tris,vw,nw,cw=_new_writers()
        _box_tris(tris,_add_box(vw,nw,cw,cx,cy,cz,sx,sy,sz,r,g,b))
        np=_build_mesh(vdata,tris); np.reparentTo(root); return np

    # Body
    solid("body",     0.,1.36, 0.,  0.60,0.72,1.50, *HC)
    solid("rump",     0.,1.42,-0.62,0.54,0.58,0.36, *HC)
    solid("chest",    0.,1.38, 0.68,0.52,0.56,0.38, *HC)
    solid("saddle",   0.,1.74, 0.,  0.62,0.08,0.80, 165,42,22)
    solid("neck",     0.,1.72, 0.62,0.30,0.44,0.30, *HC)
    solid("head",     0.,1.88, 0.96,0.24,0.28,0.52, *HC)
    solid("muzzle",   0.,1.72, 1.14,0.18,0.18,0.28, HD[0]-5,HD[1]-5,HD[2]-3)
    solid("ear_l",   -0.10,2.06,0.84,0.08,0.16,0.08, *HM)
    solid("ear_r",    0.10,2.06,0.84,0.08,0.16,0.08, *HM)
    solid("eye_l",   -0.13,1.91,1.06,0.04,0.06,0.06, 18,10,4)
    solid("eye_r",    0.13,1.91,1.06,0.04,0.06,0.06, 18,10,4)
    solid("mane",     0.,1.92, 0.72,0.10,0.34,0.46, *HM)
    solid("tail",     0.,1.44,-0.88,0.12,0.52,0.14, *HM)

    # Legs — each as a pivot NodePath so we can rotate them
    leg_defs = [
        ("leg_fl", -0.20,  0.32),
        ("leg_fr",  0.20,  0.32),
        ("leg_bl", -0.20, -0.38),
        ("leg_br",  0.20, -0.38),
    ]
    for name, lx, lz in leg_defs:
        pivot = root.attachNewNode(name)
        pivot.setPos(lx, lz, 1.10)   # pivot at hip/shoulder height
        vdata,tris,vw,nw,cw=_new_writers()
        # Upper leg
        _box_tris(tris,_add_box(vw,nw,cw,0.,-0.55,0.,0.20,1.10,0.20,*HD))
        # Hoof
        _box_tris(tris,_add_box(vw,nw,cw,0.,-1.10,0.,0.20,0.16,0.22,*HM))
        leg_mesh=_build_mesh(vdata,tris); leg_mesh.reparentTo(pivot)

    return root


# ── Articulated trooper — named arm node for aim animation ────────────────────

def make_trooper_articulated(parent: NodePath) -> NodePath:
    """Union 7th Cavalry trooper. Height ~2.0u. Feet at Z=0.
    Iteration 3: slimmer boots, visible leg gap, coat detail, face features,
    rifle rests on shoulder at parade rest by default."""
    root = parent.attachNewNode("trooper_root")

    def B(cx,cy,cz,sx,sy,sz,r,g,b):
        vdata,tris,vw,nw,cw=_new_writers()
        _box_tris(tris,_add_box(vw,nw,cw,cx,cy,cz,sx,sy,sz,r,g,b))
        _build_mesh(vdata,tris).reparentTo(root)

    # ── Boots  0.00-0.22  (slimmer, less dominant) ────────────
    B(-0.09, 0.11, 0.01,  0.15, 0.22, 0.18,  32,20,10)
    B( 0.09, 0.11, 0.01,  0.15, 0.22, 0.18,  32,20,10)

    # ── Trousers  0.20-0.90  (clear gap between legs) ─────────
    B(-0.09, 0.55, 0.00,  0.15, 0.70, 0.16,  52,65,90)
    B( 0.09, 0.55, 0.00,  0.15, 0.70, 0.16,  52,65,90)
    # Yellow seam stripe
    B(-0.17, 0.55, 0.00,  0.02, 0.68, 0.02, 192,158,44)
    B( 0.17, 0.55, 0.00,  0.02, 0.68, 0.02, 192,158,44)

    # ── Coat/Torso  0.88-1.44 ─────────────────────────────────
    # Hip section
    B( 0.00, 0.98, 0.00,  0.36, 0.20, 0.22,  42,60,82)
    # Mid chest
    B( 0.00, 1.16, 0.00,  0.38, 0.24, 0.22,  44,62,84)
    # Shoulder/upper chest — widest point
    B( 0.00, 1.33, 0.00,  0.42, 0.22, 0.22,  46,64,86)
    # Dark blue collar
    B( 0.00, 1.43, 0.00,  0.28, 0.06, 0.20,  28,38,58)
    # Belt
    B( 0.00, 0.90, 0.00,  0.38, 0.05, 0.24, 148,118,40)
    # Cartridge box
    B( 0.16, 0.92, 0.12,  0.09, 0.08, 0.06,  22,14, 8)
    # Three brass buttons
    for by in [1.02, 1.14, 1.26]:
        B(0.00, by, 0.12,  0.04, 0.04, 0.03, 190,158,46)
    # Dark lapel V-shape on chest
    B(-0.06, 1.22, 0.12,  0.06, 0.22, 0.02,  30,42,62)
    B( 0.06, 1.22, 0.12,  0.06, 0.22, 0.02,  30,42,62)

    # ── Left arm  0.94-1.38 (resting at side) ─────────────────
    B(-0.26, 1.15, 0.00,  0.13, 0.44, 0.14,  44,62,84)
    B(-0.26, 0.93, 0.00,  0.12, 0.14, 0.13, 205,168,122)

    # ── Neck  1.42-1.52 ───────────────────────────────────────
    B( 0.00, 1.47, 0.00,  0.13, 0.10, 0.12, 200,162,118)

    # ── Head  1.50-1.78 ───────────────────────────────────────
    B( 0.00, 1.64, 0.00,  0.26, 0.28, 0.22, 205,168,122)
    # Eyes — dark dots on front face
    B(-0.07, 1.68, 0.12,  0.05, 0.04, 0.02,  45,30,20)
    B( 0.07, 1.68, 0.12,  0.05, 0.04, 0.02,  45,30,20)
    # Nose
    B( 0.00, 1.62, 0.12,  0.04, 0.04, 0.02, 185,145,100)
    # Mouth / chin shadow
    B( 0.00, 1.55, 0.11,  0.08, 0.03, 0.02, 170,125,90)
    # Moustache (Custer-style)
    B( 0.00, 1.59, 0.12,  0.10, 0.03, 0.02,  80,50,30)

    # ── Campaign hat  1.76-1.96 ────────────────────────────────
    B( 0.00, 1.78, 0.00,  0.36, 0.04, 0.34,  18,12, 6)  # brim
    B( 0.00, 1.87, 0.00,  0.22, 0.18, 0.22,  18,12, 6)  # crown
    B( 0.00, 1.78, 0.00,  0.24, 0.04, 0.24, 152,120,42)  # gold band

    # ── Right arm — pivot at shoulder, rifle at parade rest ────
    # Shoulder is at Z=1.38 in root space
    arm_pivot = root.attachNewNode("right_arm")
    arm_pivot.setPos(0.25, 0.00, 1.38)

    vdata,tris,vw,nw,cw=_new_writers()
    # Upper arm (hangs down from shoulder pivot)
    _box_tris(tris,_add_box(vw,nw,cw,
        0.00, -0.22, 0.00,   0.13, 0.44, 0.14,  44,62,84))
    # Forearm + hand
    _box_tris(tris,_add_box(vw,nw,cw,
        0.00, -0.44, 0.00,   0.12, 0.14, 0.12,  205,168,122))
    # Springfield carbine — stock at hand, barrel upward along arm axis
    # Stock (at hand level)
    _box_tris(tris,_add_box(vw,nw,cw,
        0.01, -0.38, 0.06,   0.06, 0.28, 0.06,  65,48,22))
    # Receiver
    _box_tris(tris,_add_box(vw,nw,cw,
        0.01, -0.12, 0.07,   0.06, 0.16, 0.08,  50,46,40))
    # Barrel — extends upward past shoulder
    _box_tris(tris,_add_box(vw,nw,cw,
        0.01,  0.20, 0.07,   0.04, 0.80, 0.04,  38,34,30))
    arm_mesh=_build_mesh(vdata,tris); arm_mesh.reparentTo(arm_pivot)

    return root


